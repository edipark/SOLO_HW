<?xml version="1.0"?>
<!-- Dextra lower-body URDF for Isaac Lab AMP training.
     Collision geometry mirrors the MuJoCo XML:
       - body links use mesh collision (group 0)
       - foot links (AnkleRoll) use flat box collision pads (group 2)
       - HipYaw links have no collision (tiny intermediate joints) -->
<robot name="Dextra_lowerbody">

  <link name="base_link">
    <inertial>
      <origin xyz="0.001657726 0.000000461 0.028220216" rpy="0 0 0"/>
      <mass value="0.3676861824"/>
      <inertia ixx="1.08e-03" iyy="7.14e-04" izz="7.28e-04" ixy="0.00e+00" ixz="0.00e+00" iyz="0.00e+00"/>
    </inertial>
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/base_link.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="meshes/base_link.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

